# Caddy reverse proxy for the joint deploy (auto-TLS via Let's Encrypt).
# Replace the hostnames with your real domains before use.
#
# The CEO dashboard (public, behind auth) and the Lexi webhook ingress are the
# only public surfaces. The Lexi read-only API (127.0.0.1:8081) is NEVER proxied.

dash.example.com {
	encode gzip
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
	}
	reverse_proxy 127.0.0.1:3000
}

# Composio webhook ingress for the Lexi agent (only the webhook path is exposed).
agent.example.com {
	encode gzip
	handle /webhook* {
		reverse_proxy 127.0.0.1:8780
	}
	# Everything else on this host is closed.
	handle {
		respond "Not found" 404
	}
}
