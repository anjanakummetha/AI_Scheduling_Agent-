# ─────────────────────────────────────────────────────────────
# Lexi — Environment (Phase B UAT: read Kory, write sandbox only)
# ─────────────────────────────────────────────────────────────

COMPOSIO_API_KEY=your_composio_api_key_here

# ── READ: Kory's Outlook (inbox + calendar truth) ────────────
KORY_COMPOSIO_CONNECTION_ID=ca_kory_outlook_here
COMPOSIO_ENTITY_ID=kory_composio_entity_id_here

# ── WRITE: sandbox pilot or Kory cutover ─────────────────────
LEXI_WRITE_MODE=sandbox
SANDBOX_COMPOSIO_CONNECTION_ID=ca_sandbox_outlook_here
SANDBOX_COMPOSIO_ENTITY_ID=sandbox_entity_id_here
SANDBOX_MAILBOX_EMAIL=your-test-outlook@outlook.com
SANDBOX_EMAIL_LOOPBACK=true

# Lexi mailbox — production sends from lexi@ (approval required in Teams)
LEXI_COMPOSIO_CONNECTION_ID=
LEXI_MAILBOX_EMAIL=lexi@iconicfounders.com
LEXI_DEFAULT_SEND_CHANNEL=lexi
LEXI_HTML_SIGNATURE_ENABLED=true
LEXI_SIGNATURE_EMBED_LOGO=true
# LEXI_SIGNATURE_LOGO_URL=https://your-cdn/ifg_lexi_signature_logo.png

# Production cutover later (after UAT + Kory sign-off):
# LEXI_WRITE_MODE=kory
# SANDBOX_EMAIL_LOOPBACK=false

# ── LLM (background + Hermes when using API key path) ─────────
# Recommended: claude-sonnet-4-6 (tool-use, 200k context, speed/cost balance)
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-6

# ── Asana: Kory NON-IFG → Reservation Reminders section ───────
ASANA_COMPOSIO_CONNECTION_ID=
ASANA_PROJECT_GID=1211141447026980
ASANA_SECTION_GID=1215589721947621
KORY_SENDER_EMAILS=kory@ifg.vc,kory@iconicfounders.com
ASANA_ENABLED=true

# ── HubSpot (read + approval-gated cleanup/outreach) ─────────
HUBSPOT_COMPOSIO_CONNECTION_ID=
# Keep false until Kory explicitly enables live CRM/task writes
LEXI_ASANA_LIVE_WRITES_ENABLED=false
LEXI_HUBSPOT_LIVE_WRITES_ENABLED=false
# Outreach campaigns: drafts stay local; sends stay blocked until you enable these
LEXI_OUTREACH_LIVE_SENDS_ENABLED=false
LEXI_OUTREACH_OUTLOOK_DRAFTS_ENABLED=false
# Optional related Asana projects: name:gid,name:gid
# ASANA_RELATED_PROJECT_GIDS=Call List:123,Another:456
ASANA_RELATED_PROJECT_GIDS=

# ── Kory briefings & reminders ───────────────────────────────
LEXI_KORY_REMINDER_HOURS=24
LEXI_DAILY_BRIEFING_HOUR_MT=4
LEXI_DAILY_BRIEFING_MINUTE_MT=45
LEXI_DAILY_BRIEFING_WINDOW_MIN=20

# ── Lexi worker (production: webhook-first ingress) ───────────
LEXI_EMBED_WORKER=true
LEXI_ORCHESTRATOR_ENABLED=true
LEXI_ORCHESTRATOR_INTERVAL=30
# Frequent poll (~43k Composio calls/month idle) — use only for local dev without webhook
LEXI_ORCHESTRATOR_POLL_OUTLOOK=false
# Slow safety net if a webhook is missed (30m ≈ 48 list calls/day)
LEXI_ORCHESTRATOR_BACKUP_POLL_MINUTES=30
LEXI_WEBHOOK_ENABLED=true
LEXI_WEBHOOK_PORT=8780
LEXI_WEBHOOK_HOST=0.0.0.0
# Stable public URL after deploy (register once with scripts/register_composio_webhook.py)
LEXI_WEBHOOK_PUBLIC_URL=https://your-stable-host.example.com
LEXI_AUTO_EXECUTE_ENABLED=false
LEXI_AUTO_EXECUTE_CONFIDENCE=0.95

# ── Safety (production: live writes with Teams approval) ─────
LEXI_REQUIRE_KORY_APPROVAL=true
LEXI_ALLOW_IMMEDIATE_SEND=false
# UAT prep: true = no Outlook writes (emails/holds/invites staged only)
LEXI_DRY_RUN=true
# UAT prep: true = no Teams cards/messages pushed (logic still runs; check DB/audit)
LEXI_SUPPRESS_TEAMS_PUSH=true
HEIDI_ESCALATION_EMAIL=Heidi.Heckler@iconicfounders.com
# When false, escalation emails go only to HEIDI_ESCALATION_EMAIL (no Kory CC).
HEIDI_ESCALATION_CC_KORY=false
# Production cutover: false = live kory@ifg.vc sends + calendar writes (still approval-gated)
LEXI_KORY_OUTBOUND_BLOCKED=false
LEXI_KORY_SPACE_READ_ONLY=false
LEXI_ASANA_AUTO_CREATE=false
DEMO_MODE=false

# ── Lexi mailbox (production: sends from lexi@ with Teams approval)
# LEXI_COMPOSIO_CONNECTION_ID=
# LEXI_MAILBOX_EMAIL=lexi@iconicfounders.com
LEXI_DEFAULT_SEND_CHANNEL=lexi
LEXI_DELEGATION_AUTO_DRAFT=true
LEXI_DELEGATION_CC_ONLY=true
LEXI_TEAMS_INBOUND_NOTIFY_MODE=delegation_and_followups
LEXI_COMPOSIO_SEARCH_ENABLED=true

# ── Long-term DB retention (automatic via orchestrator) ───────
LEXI_AUDIT_RETENTION_DAYS=180
LEXI_SESSION_TTL_DAYS=7
LEXI_SESSION_CLOSED_RETENTION_DAYS=90
LEXI_SESSION_CONTEXT_MAX_CHARS=32000
LEXI_RAW_BODY_RETENTION_DAYS=120
LEXI_DB_MAINTENANCE_EVERY_CYCLES=120

# ── Teams (Hermes :3978) ─────────────────────────────────────
LEXI_TEAMS_ENABLED=true
LEXI_TEAMS_TEXT_ONLY=false
TEAMS_CLIENT_ID=
TEAMS_TENANT_ID=
TEAMS_CLIENT_SECRET=
TEAMS_ALLOWED_USERS=
TEAMS_CONVERSATION_ID=
TEAMS_SERVICE_URL=https://smba.trafficmanager.net/amer/

# ── Timezones ────────────────────────────────────────────────
# Kory's home / scheduling rules (MT). Recipient TZ first on outbound mail.
SCHEDULING_TIMEZONE=America/Denver
LEXI_CALENDAR_SEARCH_DAYS=60
LEXI_CALENDAR_SEARCH_DAYS_MAX=120
# Internal only: default TZ on Graph payloads when an event omits offset (not Kory's location).
OUTLOOK_TIMEZONE=America/New_York
