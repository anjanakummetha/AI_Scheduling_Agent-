# ─────────────────────────────────────────────────────────────
# Kory's AI Scheduling Agent — Environment Variables
# ─────────────────────────────────────────────────────────────
# 1. Copy this file: cp .env.example .env
# 2. Fill in your values below
# 3. Never commit .env to git
# ─────────────────────────────────────────────────────────────

# ── Composio ─────────────────────────────────────────────────
# Get this from: dashboard.composio.dev → Settings → API Keys
COMPOSIO_API_KEY=your_composio_api_key_here

# The user ID that maps to Kory's connected Microsoft 365 account
# This is whatever you used when connecting the account in the dashboard
COMPOSIO_USER_ID=kory

# ── LLM (Hermes) ─────────────────────────────────────────────
# OPTION A: Ollama running locally (free)
#   - Install Ollama: https://ollama.com
#   - Pull the model: ollama pull hermes3
#   - Leave these defaults as-is:
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=hermes3

# ── Demo App ─────────────────────────────────────────────────
# Keeps local workflows safe while wiring the dashboard.
DEMO_MODE=true

# OPTION B: Together AI (cloud-hosted Hermes, easy setup)
#   - Sign up at: https://api.together.xyz
#   - Uncomment and fill in:
# LLM_BASE_URL=https://api.together.xyz/v1
# LLM_API_KEY=your_together_ai_key_here
# LLM_MODEL=NousResearch/Hermes-3-Llama-3.1-70B-Turbo

# OPTION C: OpenRouter (aggregator, many models)
#   - Sign up at: https://openrouter.ai
#   - Uncomment and fill in:
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=your_openrouter_key_here
# LLM_MODEL=anthropic/claude-3.5-haiku   ← recommended (supports tool calling for calendar/email)
# LLM_MODEL=nousresearch/hermes-4-70b    ← conversation only, no tool calling on OpenRouter
