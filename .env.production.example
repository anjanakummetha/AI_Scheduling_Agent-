# ─────────────────────────────────────────────────────────────
# Lexi — PRODUCTION env template (plan Phase 6 cutover)
# Copy to .env.production and run with LEXI_ENV=production (systemd sets this).
# The safety gates below start CLOSED. Open them ONE step at a time along the
# enablement ladder (holds-only → drafts-only → approved sends), soaking between.
# ─────────────────────────────────────────────────────────────

LEXI_ENV=production

# ── Production Anthropic key ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your_PRODUCTION_key_here
LEXI_LLM_MODEL_TRIAGE=claude-haiku-4-5
LEXI_LLM_MODEL_SCHEDULER=claude-sonnet-5
LEXI_LLM_MODEL_DRAFTING=claude-sonnet-5

# ── Composio (production Kory + Lexi + Asana + HubSpot connections) ──
COMPOSIO_API_KEY=your_composio_api_key_here
KORY_COMPOSIO_CONNECTION_ID=ca_kory_outlook_here
COMPOSIO_ENTITY_ID=Kory
LEXI_COMPOSIO_CONNECTION_ID=ca_lexi_outlook_here
LEXI_MAILBOX_EMAIL=lexi@iconicfounders.com
ASANA_COMPOSIO_CONNECTION_ID=ca_asana_here
ASANA_PROJECT_GID=
HUBSPOT_COMPOSIO_CONNECTION_ID=ca_hubspot_here   # read-only first (plan Phase 5)

# ── ENABLEMENT LADDER — advance one rung at a time, soak between ──
# Rung 1  calendar holds/invites only:  WRITE_MODE=kory, DRY_RUN=false,
#         OUTBOUND_BLOCKED=true, SPACE_READ_ONLY=false
# Rung 2  drafts-only outbound:         OUTLOOK_DRAFTS on, SEND still blocked
# Rung 3  approved sends:               OUTBOUND_BLOCKED=false, REQUIRE_APPROVAL=true
LEXI_WRITE_MODE=sandbox            # → kory at Rung 1
LEXI_DRY_RUN=true                  # → false at Rung 1
LEXI_KORY_SPACE_READ_ONLY=true     # → false at Rung 1 (calendar holds)
LEXI_KORY_OUTBOUND_BLOCKED=true    # → false at Rung 3 (approved email)
LEXI_REQUIRE_KORY_APPROVAL=true    # keep true — every send needs a Teams tap
LEXI_ALLOW_IMMEDIATE_SEND=false
LEXI_AUTO_EXECUTE_ENABLED=false
LEXI_ASANA_LIVE_WRITES_ENABLED=false      # opt in after email is stable
LEXI_HUBSPOT_LIVE_WRITES_ENABLED=false
LEXI_OUTREACH_LIVE_SENDS_ENABLED=false    # outreach sends last
LEXI_OUTREACH_OUTLOOK_DRAFTS_ENABLED=false
LEXI_HEIDI_ESCALATION_ENABLED=false       # issues route to Kory via Teams

# ── Teams (Hermes gateway) ───────────────────────────────────
LEXI_TEAMS_ENABLED=true
LEXI_SUPPRESS_TEAMS_PUSH=false
LEXI_TEAMS_TEXT_ONLY=false   # interactive Adaptive Cards (editable draft + Send/Discard), not plain text
TEAMS_CLIENT_ID=
TEAMS_TENANT_ID=
TEAMS_CLIENT_SECRET=
TEAMS_SERVICE_URL=
TEAMS_ALLOWED_USERS=

# ── Ingress / worker ─────────────────────────────────────────
LEXI_EMBED_WORKER=true
LEXI_ORCHESTRATOR_ENABLED=true
LEXI_ORCHESTRATOR_INTERVAL=30
LEXI_WEBHOOK_ENABLED=true
LEXI_WEBHOOK_PORT=8780
LEXI_WEBHOOK_PUBLIC_URL=https://your-vps-public-url/webhook
LEXI_ORCHESTRATOR_BACKUP_POLL_MINUTES=30   # never per-cycle poll (Composio budget)
LEXI_COMPOSIO_TIMEOUT_SECONDS=30           # per-request timeout so a stuck call can't hang the worker

SCHEDULING_TIMEZONE=America/Denver
OUTLOOK_TIMEZONE=America/New_York
LEXI_DATABASE_PATH=data/lexi.db

# ── Email identity: CC Kory + log to HubSpot ─────────────────
# Addresses Kory sends from (delegation detection).
KORY_SENDER_EMAILS=kory.mitchell@iconicfounders.com,kory@iconicfounders.com,kory@ifg.vc
# Kory's real primary address — Lexi CCs him on the mail she sends so he stays in the loop.
KORY_CC_EMAIL=Kory.Mitchell@iconicfounders.com
LEXI_CC_KORY_ENABLED=true
# Auto-BCC scheduling mail to outsiders into HubSpot for logging.
LEXI_HUBSPOT_BCC_ADDRESS=242757246@bcc.na2.hubspot.com
LEXI_HUBSPOT_BCC_ENABLED=true

# ── Read-only /api/v1 for the CEO dashboard (localhost only via lexi-api.service) ──
LEXI_API_ENABLED=true
LEXI_API_TOKEN=            # shared secret; must match the dashboard's LEXI_API_TOKEN
