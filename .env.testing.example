# ─────────────────────────────────────────────────────────────
# Lexi — TESTING env template (plan Phase 1)
# Copy to .env.testing and run with LEXI_ENV=testing (or LEXI_ENV_FILE=.env.testing).
# This is the fail-safe default: every gate on, writes to sandbox only, and the
# recipient allowlist blocks any real, non-sandbox recipient regardless of flags.
# ─────────────────────────────────────────────────────────────

LEXI_ENV=testing

# ── Dev Anthropic key (create a SEPARATE key/workspace with a low spend cap) ──
ANTHROPIC_API_KEY=sk-ant-your_DEV_testing_key_here
# Cost-tiered models (plan Phase 3): Haiku triage / Sonnet drafting.
LEXI_LLM_MODEL_TRIAGE=claude-haiku-4-5
LEXI_LLM_MODEL_SCHEDULER=claude-sonnet-5
LEXI_LLM_MODEL_DRAFTING=claude-sonnet-5

# ── Composio (may reuse the existing account; testing writes go to sandbox) ──
COMPOSIO_API_KEY=your_composio_api_key_here
KORY_COMPOSIO_CONNECTION_ID=ca_kory_outlook_here     # READ ONLY in testing
COMPOSIO_ENTITY_ID=Kory
SANDBOX_COMPOSIO_CONNECTION_ID=ca_sandbox_outlook_here
SANDBOX_COMPOSIO_ENTITY_ID=sandbox_entity_id_here
SANDBOX_MAILBOX_EMAIL=your-test-outlook@outlook.com
SANDBOX_EMAIL_LOOPBACK=true

# ── SAFETY GATES — all on for testing (do not relax here) ────
LEXI_WRITE_MODE=sandbox            # coherence-validated: testing must never be 'kory'
LEXI_DRY_RUN=true
LEXI_KORY_OUTBOUND_BLOCKED=true
LEXI_KORY_SPACE_READ_ONLY=true
LEXI_REQUIRE_KORY_APPROVAL=true
LEXI_AUTO_EXECUTE_ENABLED=false
LEXI_ALLOW_IMMEDIATE_SEND=false
LEXI_ASANA_LIVE_WRITES_ENABLED=false
LEXI_HUBSPOT_LIVE_WRITES_ENABLED=false
LEXI_OUTREACH_LIVE_SENDS_ENABLED=false
LEXI_OUTREACH_OUTLOOK_DRAFTS_ENABLED=false
LEXI_HEIDI_ESCALATION_ENABLED=false   # issues route to Kory via Teams, not Heidi

# ── Recipient allowlist — the structural send guard ──────────
# Only these addresses may ever receive a real send/invite in testing.
LEXI_ALLOWED_RECIPIENTS=your-test-outlook@outlook.com

# ── Ingress / worker ─────────────────────────────────────────
LEXI_EMBED_WORKER=false
LEXI_ORCHESTRATOR_ENABLED=false
LEXI_TEAMS_ENABLED=false
LEXI_SUPPRESS_TEAMS_PUSH=true

SCHEDULING_TIMEZONE=America/Denver
OUTLOOK_TIMEZONE=America/New_York
LEXI_DATABASE_PATH=data/lexi_test.db
